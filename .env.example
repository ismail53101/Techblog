# ==================================================================
# Core site configuration
# ==================================================================
# Public URL of the site (NO trailing slash).
# Used for canonical URLs, sitemap, RSS, and Open Graph images.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="FixPedia"
NEXT_PUBLIC_SITE_DESCRIPTION="Practical tech guides, reviews, and fixes for AI tools, Windows, Android, iPhone, software, and cybersecurity."

# ==================================================================
# Database (PostgreSQL)
# Providers: Neon, Supabase, Railway, Vercel Postgres, or local Postgres.
# ==================================================================
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public&sslmode=require"

# ==================================================================
# Authentication (Auth.js / NextAuth v5)
# Generate AUTH_SECRET with:  openssl rand -base64 32
# ==================================================================
AUTH_SECRET="replace-with-a-long-random-string"
# Set to your production URL when deploying (e.g. https://yourdomain.com)
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# ==================================================================
# Seed admin account (used by:  npm run db:seed)
# Change these before seeding a production database.
# ==================================================================
ADMIN_NAME="Site Admin"
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="ChangeMe123!"

# ==================================================================
# Cloudinary (image storage & optimization)
# Values are in your Cloudinary dashboard.
# ==================================================================
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"
CLOUDINARY_FOLDER="fixpedia"

# ==================================================================
# Scheduled publishing cron
# Vercel Cron calls /api/cron/publish with:  Authorization: Bearer <CRON_SECRET>
# ==================================================================
CRON_SECRET="replace-with-a-long-random-string"

# ==================================================================
# Optional — transactional email (Resend) for contact form.
# Leave RESEND_API_KEY blank to only store submissions in the database.
# ==================================================================
RESEND_API_KEY=""
CONTACT_TO_EMAIL="you@example.com"

# ==================================================================
# Optional — Upstash Redis for distributed rate limiting in production.
# Leave blank to use the built-in in-memory limiter.
# ==================================================================
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
